# =============================================================================
# Firecrawl MPP Proxy Configuration
# =============================================================================

# --- Required ---

# Firecrawl API key — get one at https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# MPP recipient address (your Movement wallet that receives payments)
RECIPIENT=0xYOUR_WALLET_ADDRESS_HERE

# --- Production (set these for deployment) ---

# Secret key for signing MPP challenges. If not set, a random key is generated
# on each restart (fine for testing, breaks in-flight payments on restart).
# Generate one: openssl rand -hex 32
# MPP_SECRET_KEY=

# Movement REST API URL. Defaults to testnet.
# MOVEMENT_REST_URL=https://mainnet.movementnetwork.xyz/v1

# Allowed CORS origin. If not set, CORS is permissive (dev mode).
# Set to your frontend URL in production.
# CORS_ORIGIN=https://your-app.example.com

# Bind address. Defaults to 0.0.0.0:3010.
# BIND_ADDR=0.0.0.0:3010

# Rate limit per IP per minute. Defaults to 30.
# RATE_LIMIT_PER_MINUTE=30
