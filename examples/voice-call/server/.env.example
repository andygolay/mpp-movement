# =============================================================================
# Voice Call Server — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# REQUIRED — HMAC secret for MPP payment challenges and WebSocket auth tokens.
# Generate with: openssl rand -base64 32
SECRET_KEY=

# HTTP listen port. Default: 3002
PORT=3002

# Movement on-chain module address for the payment channel contract.
# Default: testnet address. Change to mainnet address for production.
MODULE_ADDRESS=0x74f1060add0c641a0c10bb5bab2bf5fd05f94d7c25055f2419fa82d7bbf2b1e8

# Movement REST API URL.
# Default: testnet. Change to mainnet for production.
REST_URL=https://testnet.movementnetwork.xyz/v1

# Comma-separated list of allowed CORS origins.
# If unset, all origins are allowed (suitable for local dev only).
# Example: https://your-app.vercel.app,https://yourdomain.com
ALLOWED_ORIGINS=

# Logging level. Uses the tracing/env_filter syntax.
# Examples: info, debug, voice_call_server=debug, warn
RUST_LOG=info

# Log format. Set to "json" for structured JSON output (recommended for production).
# Any other value (or unset) uses human-readable format.
LOG_FORMAT=
