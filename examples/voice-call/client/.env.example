# =============================================================================
# Voice Call Client — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# All variables are prefixed with VITE_ so Vite exposes them to the client bundle.

# Server URL (the Rust signaling server).
# Default: http://localhost:3002 (local dev)
VITE_SERVER_URL=http://localhost:3002

# Movement on-chain module address for the payment channel contract.
# Must match the server's MODULE_ADDRESS.
VITE_MODULE_ADDRESS=0x74f1060add0c641a0c10bb5bab2bf5fd05f94d7c25055f2419fa82d7bbf2b1e8

# Registry address (defaults to MODULE_ADDRESS if unset).
VITE_REGISTRY_ADDR=

# Token metadata address. 0xa = native MOVE token.
VITE_TOKEN_METADATA_ADDR=0xa

# Display symbol for the token.
VITE_TOKEN_SYMBOL=MOVE

# Decimal places for the token.
VITE_TOKEN_DECIMALS=8

# TURN server configuration — required for calls across different networks.
# Without a TURN server, calls only work on the same LAN.
# Example: turn:turn.yourdomain.com:3478
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
