# Payment token FA metadata address
# MOVE (default): 0xa
# USDCx on testnet: 0x63f169ba69623ba6ccf34620857644feb46d0f87e1d7bbcf8c071d30c3d94bd6
TOKEN_METADATA=0x63f169ba69623ba6ccf34620857644feb46d0f87e1d7bbcf8c071d30c3d94bd6

# Price per streamed token in base units
# MOVE (8 decimals): 1000 = 0.00001 MOVE
# USDCx (6 decimals): 10 = 0.00001 USDCx
PRICE_PER_TOKEN=10

# Suggested deposit in base units
# MOVE: 100000 = 0.001 MOVE
# USDCx: 10000 = 0.01 USDCx
SUGGESTED_DEPOSIT=10000

# HMAC secret for 402 challenge ID binding (optional)
