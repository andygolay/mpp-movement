# =============================================================================
# Search → Image → Email
# =============================================================================

# --- Required ---

# Exa search API key — get one at https://dashboard.exa.ai/api-keys
EXA_API_KEY=exa-...

# fal.ai API key — get one at https://fal.ai/dashboard/keys
FAL_API_KEY=fal-...

# Resend email API key — get one at https://resend.com/api-keys
RESEND_API_KEY=re_...

# MPP recipient address (your Movement wallet that receives payments)
RECIPIENT=0xYOUR_WALLET_ADDRESS_HERE

# --- Optional ---

# Email sender address (must be verified in Resend, or use their test domain)
FROM_EMAIL=MPP Search <onboarding@resend.dev>

# Movement REST API URL. Defaults to testnet.
# MOVEMENT_REST_URL=https://mainnet.movementnetwork.xyz/v1

# MPP challenge signing secret. Auto-generated if not set.
# MPP_SECRET_KEY=

# CORS_ORIGIN=https://your-app.example.com
# BIND_ADDR=0.0.0.0:3020
# RATE_LIMIT_PER_MINUTE=20
